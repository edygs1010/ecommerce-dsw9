<div class="jumbotron">
  <h1 class="display-4">Bienvenido a Mi Tienda</h1>
  <p class="lead">Descubre nuestros productos al mejor precio.</p>
  <a class="btn btn-primary btn-lg" href="/products">Ver productos</a>
</div>
<h2 class="mb-4">Productos Destacados</h2>
<div class="row">
  <% if (featuredProducts.length === 0) { %>
    <div class="col-12"><div class="alert alert-info">No hay productos.</div></div>
  <% } %>
  <% for (let product of featuredProducts) { %>
    <div class="col-md-4 mb-4">
      <div class="card product-card">
        <img src="<%= product.imageUrl %>" class="card-img-top" alt="<%= product.name %>" onerror="this.src='/images/placeholder.jpg'">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= product.name %></h5>
          <p class="card-text text-muted text-truncate"><%= product.description %></p>
          <p class="card-text"><strong class="text-primary h5">$<%= parseFloat(product.price).toFixed(2) %></strong></p>
          <div class="d-flex justify-content-between mt-auto">
            <a href="/products/<%= product.id %>" class="btn btn-outline-primary btn-sm">Ver</a>
            <form action="/cart/add" method="POST">
              <input type="hidden" name="productId" value="<%= product.id %>">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="btn btn-primary btn-sm" <%= product.stock === 0 ? 'disabled' : '' %>>
                <%= product.stock === 0 ? 'Agotado' : 'Agregar' %>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  <% } %>
</div>