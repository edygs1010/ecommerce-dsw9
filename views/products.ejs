<h1 class="mb-4">Catalogo de Productos</h1>
<% if (products.length === 0) { %>
  <div class="alert alert-info">No hay productos disponibles.</div>
<% } else { %>
  <div class="row">
    <% for (let product of products) { %>
      <div class="col-md-4 mb-4">
        <div class="card product-card">
          <img src="<%= product.imageUrl %>" class="card-img-top" onerror="this.src='/images/placeholder.jpg'">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= product.name %></h5>
            <p class="card-text text-muted text-truncate"><%= product.description %></p>
            <p class="card-text"><strong class="text-primary h5">$<%= parseFloat(product.price).toFixed(2) %></strong></p>
            <% if (product.stock > 0) { %>
              <small class="text-success mb-2">En stock (<%= product.stock %>)</small>
            <% } else { %>
              <small class="text-danger mb-2">Agotado</small>
            <% } %>
            <div class="d-flex justify-content-between mt-auto">
              <a href="/products/<%= product.id %>" class="btn btn-outline-primary btn-sm">Detalles</a>
              <form action="/cart/add" method="POST">
                <input type="hidden" name="productId" value="<%= product.id %>">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" class="btn btn-primary btn-sm" <%= product.stock === 0 ? 'disabled' : '' %>>
                  <%= product.stock === 0 ? 'Agotado' : 'Agregar' %>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
<% } %>